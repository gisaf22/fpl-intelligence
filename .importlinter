[importlinter]
root_packages =
    dal
    domain
    research
    model
    serve

[importlinter:contract:no_domain_to_anything]
name = Domain is the shared leaf — must import nothing project-internal
type = forbidden
source_modules =
    domain
forbidden_modules =
    dal
    research
    model
    serve

[importlinter:contract:no_research_to_downstream]
name = Research must not import from downstream layers
type = forbidden
source_modules =
    research
forbidden_modules =
    model
    serve

[importlinter:contract:no_serve_to_research_or_model]
name = Intelligence must not import from research or model
type = forbidden
source_modules =
    serve
forbidden_modules =
    research
    model

[importlinter:contract:no_diagnostic_to_predictive_layers]
name = Diagnostic (Rung 2) must not import predictive/operational research layers
type = forbidden
source_modules =
    research.diagnostic
forbidden_modules =
    research.families
    research.findings

[importlinter:contract:no_model_to_research_analysis]
name = Model must not import research analysis or findings (kernels exempt)
type = forbidden
source_modules =
    model
forbidden_modules =
    research.foundation
    research.diagnostic
    research.families
    research.findings

[importlinter:contract:no_dal_to_system_layers]
name = DAL must not import from system layers
type = forbidden
source_modules =
    dal
forbidden_modules =
    research
    model
    serve
