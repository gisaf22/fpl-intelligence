[importlinter]
root_packages =
    dal
    research
    model
    signals
    intelligence

[importlinter:contract:no_research_to_downstream]
name = Research must not import from downstream layers
type = forbidden
source_modules =
    research
forbidden_modules =
    signals
    model
    intelligence

[importlinter:contract:no_signals_to_research_or_intelligence]
name = Signals must not import from research or intelligence
type = forbidden
source_modules =
    signals
forbidden_modules =
    research
    intelligence

[importlinter:contract:no_intelligence_to_research_or_model]
name = Intelligence must not import from research or model
type = forbidden
source_modules =
    intelligence
forbidden_modules =
    research
    model

[importlinter:contract:no_model_to_research_analysis]
name = Model must not import research analysis or findings (kernels exempt)
type = forbidden
source_modules =
    model
forbidden_modules =
    research.foundation
    research.families
    research.findings

[importlinter:contract:no_dal_to_system_layers]
name = DAL must not import from system layers
type = forbidden
source_modules =
    dal
forbidden_modules =
    research
    model
    signals
    intelligence
